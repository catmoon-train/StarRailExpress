{
  "modid": "starrailexpress_bat",
  "vars": {
    "modLoaded": "isModLoaded('starrailexpress')",
    "mainHandItem": "mainHandItem()",
    "keyUse": "getKeyByDesc('key.attack')",
    "screenOpen": "isScreenOpen()",
    "isCameraPlayer": "isCameraPlayer()",
    "holdingKnife": "mainHandItem() == 'trainmurdermystery:knife'"
  },
  "entries": [
    {
      "when": {
        "modLoaded": "true",
        "holdingKnife": "true",
        "screenOpen": "false",
        "isCameraPlayer": "true"
      },
      "then": [
        "custom('starrailexpress_bat', keyUse, 'key.starrailexpress.bat')"
      ]
    }
  ]
}